# PostgreSQL
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/own_workflow

# Docker Compose host port
APP_PORT=8000

# OpenAI-compatible LLM
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Content collection
TIKHUB_API_KEY=your-tikhub-api-key

# Image generation
IMAGE_PROVIDER=uni
# IMAGE_API_BASE_URL examples:
# - uni/openai compatible: https://api.uniapi.io/v1
# - ark/volc: https://ark.cn-beijing.volces.com/api/v3
IMAGE_API_BASE_URL=https://api.uniapi.io/v1
IMAGE_API_KEY=your-image-api-key
IMAGE_API_MODEL=gpt-image-2

# Scheduler
SCHEDULE_POLL_INTERVAL_SECONDS=15
SCHEDULE_STALE_LOCK_SECONDS=600

# S3-compatible object storage for generated images
S3_ENDPOINT=https://s3.example.com
S3_REGION=us-east-1
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key

# Optional S3 settings
S3_SESSION_TOKEN=
S3_KEY_PREFIX=generated-assets
S3_PUBLIC_BASE_URL=https://cdn.example.com/generated-assets
